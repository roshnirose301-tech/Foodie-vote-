from flask import Flask, request, jsonify
import sqlite3

app = Flask(__name__)

def create_table():
    conn = sqlite3.connect("database.db")
    cur = conn.cursor()

    cur.execute("""
    CREATE TABLE IF NOT EXISTS feedback(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        student_name TEXT,
        food_item TEXT,
        rating INTEGER,
        feedback TEXT
    )
    """)

    conn.commit()
    conn.close()

create_table()

@app.route("/submit", methods=["POST"])
def submit():
    data = request.get_json()

    conn = sqlite3.connect("database.db")
    cur = conn.cursor()

    cur.execute(
        "INSERT INTO feedback(student_name, food_item, rating, feedback) VALUES(?,?,?,?)",
        (
            data["student_name"],
            data["food_item"],
            data["rating"],
            data["feedback"]
        )
    )

    conn.commit()
    conn.close()

    return jsonify({"message": "Feedback Submitted Successfully"})

@app.route("/feedbacks", methods=["GET"])
def feedbacks():
    conn = sqlite3.connect("database.db")
    cur = conn.cursor()

    cur.execute("SELECT * FROM feedback")
    rows = cur.fetchall()

    conn.close()

    return jsonify(rows)

if __name__ == "__main__":
    app.run(debug=True)
